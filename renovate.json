{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "7 days",
  "schedule": ["on the 20th day of the month"],
  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.sh$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>[^\\s]+?)\\n[A-Z_]+=\"[^:]+:(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
